
# --- IA (Vercel AI Gateway) : sert à découper le texte en vrac ---
# Sur Vercel, peut être automatique via OIDC. En local, mets une clé AI Gateway.
AI_GATEWAY_API_KEY=

# --- cal.com (API v2 : stockage des rendez-vous) ---
# 1. cal.com -> Settings -> Developer -> API Keys -> crée une clé (préfixe "cal_").
CALCOM_API_KEY=cal_xxxxxxxxxxxxxxxxxxxxx
# 2. Crée un Event Type (durée du RDV, dispos) puis récupère son ID numérique.
#    Visible dans l'URL d'édition de l'event type, ou via GET /v2/event-types.
CALCOM_EVENT_TYPE_ID=123456
# Optionnel (défauts ci-dessous) :
# CALCOM_API_BASE=https://api.cal.com/v2
# CALCOM_API_VERSION=2024-08-13
# CALCOM_BOOKING_BASE=https://app.cal.com/booking

# --- Brevo (envoi des mails) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@simplisicar.fr
BREVO_SENDER_NAME=Simplisicar

# --- Divers ---
BUSINESS_NAME=Simplisicar
# Protège la route du cron. Vercel l'injecte automatiquement dans l'en-tête Authorization.
CRON_SECRET=mets-un-secret-aleatoire-ici
