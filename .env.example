# --- IA (Vercel AI Gateway) : sert à découper le texte en vrac ---
# Sur Vercel, peut être automatique via OIDC. En local, mets une clé AI Gateway.
AI_GATEWAY_API_KEY=

# --- Google Agenda (compte de service) ---
# Crée un compte de service dans Google Cloud, active l'API Calendar,
# puis PARTAGE ton agenda avec l'email du compte de service (droit "Apporter des modifications aux événements").
GOOGLE_CLIENT_EMAIL=mon-compte@mon-projet.iam.gserviceaccount.com
# Colle la clé privée sur une ligne, avec des \n littéraux (garde les guillemets).
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# L'ID de l'agenda partagé (souvent ton adresse Gmail, ou un ID @group.calendar.google.com)
GOOGLE_CALENDAR_ID=ton.email@gmail.com

# --- Brevo (envoi des mails) ---
BREVO_API_KEY=
BREVO_SENDER_EMAIL=contact@simplisicar.fr
BREVO_SENDER_NAME=Simplisicar

# --- Divers ---
BUSINESS_NAME=Simplisicar
# Protège la route du cron. Vercel l'injecte automatiquement dans l'en-tête Authorization.
CRON_SECRET=mets-un-secret-aleatoire-ici
